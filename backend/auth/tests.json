{
  "tests": [
    {
      "name": "Register new user",
      "method": "POST",
      "path": "/?action=register",
      "body": {"email": "test_luna_001@example.com", "password": "secret123", "name": "Test User"},
      "expectedStatus": 201,
      "expectedBody": {"token": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Login with wrong password",
      "method": "POST",
      "path": "/?action=login",
      "body": {"email": "test_luna_001@example.com", "password": "wrongpass"},
      "expectedStatus": 401,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Me without token",
      "method": "GET",
      "path": "/?action=me",
      "expectedStatus": 401,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Google login without token",
      "method": "POST",
      "path": "/?action=google",
      "body": {},
      "expectedStatus": 400,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Admin stats without token",
      "method": "GET",
      "path": "/?action=admin_stats",
      "expectedStatus": 401,
      "expectedBody": {"error": "Unauthorized"},
      "bodyMatcher": "partial"
    },
    {
      "name": "OPTIONS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "Get media list (public)",
      "method": "GET",
      "path": "/?action=get_media",
      "expectedStatus": 200,
      "expectedBody": {"total": 0},
      "bodyMatcher": "partial"
    },
    {
      "name": "Toggle like without token",
      "method": "POST",
      "path": "/?action=toggle_like",
      "body": {"media_id": 1},
      "expectedStatus": 401,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    }
  ]
}